--- !u!114 &554523755
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 554523753}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02de0a6454d274675a4b67d335c3e3f9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  adviceText: {fileID: 554523756}
  advices:
  - "\u8D64\u3044\u30C6\u30AD\u306F\u307E\u3063\u3059\u3050\u7A81\u3063\u8FBC\u3093\u3067\u304F\u308B\u3002\n\u6483\u3061\u843D\u3068\u305B\u306A\u3044\u6642\u306F\u3001\u907F\u3051\u308B\u306E\u3082\u624B\u3060\u308D\u3046\u3002"
  - "\u9752\u3044\u30C6\u30AD\u306F\u6CE2\u3092\u63CF\u304F\u3088\u3046\u306B\u7A81\u3063\u8FBC\u3093\u3067\u304F\u308B\u3002\n\u6CB9\u65AD\u3057\u3066\u3044\u308B\u3068\u659C\u3081\u304B\u3089\u5DEE\u3057\u8FBC\u307E\u308C\u308B\u305E\u3002"
  - "\u7DD1\u306E\u30C6\u30AD\u306F\u81EA\u6A5F\u3092\u8FFD\u3044\u304B\u3051\u3066\u304F\u308B\u3002\u305D\u3057\u3066\u786C\u3044\u3002\n\u907F\u3051\u3088\u3046\u3068\u3059\u308B\u3068\u80CC\u5F8C\u3092\u53D6\u3089\u308C\u308B\u306E\u3067\u3001\u6700\u512A\u5148\u3067\u6483\u3066\u3002\n\u300C\u653B\u6483\u529B\u4E0A\u6607\u300D\u306E\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u304C\u6709\u52B9\u3060\u3002"
  - "\u7D2B\u306E\u30C6\u30AD\u306F\u4E00\u5EA6\u6B62\u307E\u3063\u3066\u5F3E\u4E38\u3092\u3070\u3089\u6492\u304F\u3002\n\u6B62\u307E\u3063\u3066\u3044\u308B\u9593\u306F\u7121\u9632\u5099\u304B\u3082\u3057\u308C\u306A\u3044\u3002\n\u3060\u304C\u8010\u4E45\u529B\u304C\u9AD8\u3044\u306E\u3067\u6CE8\u610F\u3059\u308B\u3053\u3068\u3002"
  - "\u6575\u306E\u5F3E\u4E38\u306F\u8584\u3044\u7D2B\u8272\u3092\u3057\u3066\u3044\u308B\u3002\n\u62FE\u3063\u305F\u3089\u5F97\u70B9\u306B\u306A\u308B\u3001\n\u3068\u304B\u306F\u306A\u3044\u306E\u3067\u5FC5\u6B7B\u306B\u907F\u3051\u3066\u304F\u308C\u3002"
  - "\u300C\u653B\u6483\u529B\u4E0A\u6607\u300D\u306F\u3001\n\u81EA\u6A5F\u306E\u5F3E\u4E38\u306E\u653B\u6483\u529B\u3092\u5F37\u5316\u3059\u308B\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n\u7DD1\u3084\u7D2B\u3068\u3044\u3063\u305F\u9AD8\u8010\u4E45\u306E\u6575\u306B\u6709\u52B9\u3060\u3002"
  - "\u300C\u9023\u5C04\u901F\u5EA6\u4E0A\u6607\u300D\u306F\u3001\n\u81EA\u6A5F\u306E\u5F3E\u4E38\u306E\u9023\u5C04\u901F\u5EA6\u3092\u5F37\u5316\u3059\u308B\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n\u3082\u3063\u3068\u305F\u304F\u3055\u3093\u306E\u5F3E\u4E38\u3092\u6483\u3066\u308B\u3088\u3046\u306B\u306A\u308B\u305E\u3002"
  - "\u300C\u79FB\u52D5\u901F\u5EA6\u4E0A\u6607\u300D\u306F\u3001\n\u81EA\u6A5F\u306E\u79FB\u52D5\u901F\u5EA6\u3092\u5F37\u5316\u3059\u308B\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n\u6700\u521D\u306E\u901F\u5EA6\u3067\u306F\u6575\u3088\u308A\u3082\u9045\u3044\u304B\u3089\u3001\n\uFF11\u3001\uFF12\u56DE\u306F\u5F37\u5316\u3057\u3066\u304A\u304F\u3053\u3068\u3092\u30AA\u30B9\u30B9\u30E1\u3059\u308B\u3002"
  - "\u300C\uFF13way\u30B7\u30E7\u30C3\u30C8\u300D\u306F\u3001\n\u6587\u5B57\u901A\u308A\uFF13\u65B9\u5411\u306B\u5F3E\u4E38\u3092\u6483\u3066\u308B\u3088\u3046\u306B\u306A\u308B\n\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n\u591A\u304F\u306E\u6575\u306B\u5BFE\u3059\u308B\u6BB2\u6EC5\u529B\u304C\u30A2\u30C3\u30D7\u3059\u308B\u305E\u3002"
  - "\u300C\u8FFD\u5C3E\u30B7\u30E7\u30C3\u30C8\u300D\u306F\u3001\n\u6587\u5B57\u901A\u308A\u5F3E\u4E38\u304C\u6575\u306B\u8FFD\u5C3E\u3059\u308B\u3088\u3046\u306B\u306A\u308B\n\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n\u72D9\u3044\u6483\u3061\u304C\u3067\u304D\u306A\u3044\u306A\u3089\u3070\u3001\n\u5F3E\u306B\u8FFD\u3044\u304B\u3051\u3055\u305B\u308C\u3070\u826F\u3044\u3002"
  - "\u300C\u5F3E\u7A2E\u30EC\u30D9\u30EB\u4E0A\u6607\u300D\u306F\u3001\n\u7279\u6B8A\u306A\u5F3E\u4E38\u3092\u3055\u3089\u306B\u5F37\u5316\u3059\u308B\n\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3060\u3002\n3way\u306A\u3089\u5F3E\u306E\u6570\u304C\u5897\u3048\u308B\u3057\u3001\n\u8FFD\u5C3E\u5F3E\u306F\u8FFD\u5C3E\u529B\u304C\u30A2\u30C3\u30D7\u3059\u308B\u3002"
  - "EXP\u304C\u6E80\u30BF\u30F3\u306B\u306A\u308B\u3068\u3001\n\u753B\u9762\u5185\u306B\u3044\u308B\u3059\u3079\u3066\u306E\u30C6\u30AD\u3092\n\u4E00\u6383\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u308B\u3002\n\u305F\u3060\u3057\u3001\u5927\u304D\u306A\u30C6\u30AD\u306B\u306F\u901A\u7528\u3057\u306A\u3044\u306E\u3067\n\u6CE8\u610F\u3057\u3088\u3046\u3002"
